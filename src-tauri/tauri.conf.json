{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "PortfolioCommandCenter",
	"version": "0.1.0",
	"identifier": "dev.saagarpatel.portfoliocommandcenter",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"title": "Portfolio Command Center",
				"width": 1280,
				"height": 820,
				"minWidth": 900,
				"minHeight": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"category": "DeveloperTool",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "11.0",
			"signingIdentity": "-"
		}
	}
}
